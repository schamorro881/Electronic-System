/* No @import of less files here to avoid build issues with sass preprocessor and less imports in same file */

:root {
  --tui-primary: #3498db;
}

body {
  margin: 0;
  font-family: var(--tui-font-text);
  background-color: var(--tui-base-01);
  color: var(--tui-text-01);
}

.layout-container {
  display: flex;
  min-height: 100vh;
}

.main-wrapper {
  margin-left: 260px; /* Ancho del sidebar */
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 2rem;
  background: var(--tui-base-01);
}

.content {
  flex: 1;
}

.footer {
  text-align: center;
  color: var(--tui-text-03);
  font-size: 0.875rem;
  padding: 2rem 0;
}
